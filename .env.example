# DevFocus environment variables (never commit .env)
# Copy to .env and fill in your values
# DeepSeek API key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_key_here

# Email subscription endpoint (optional). Since the frontend is statically exported,
# use a third-party form backend such as Formspree, Buttondown, Mailchimp, or a
# separate serverless function. Example:
# NEXT_PUBLIC_SUBSCRIBE_URL=https://formspree.io/f/YOUR_FORM_ID
